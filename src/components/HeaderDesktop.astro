---
import HeaderControls from './HeaderControls.astro';
import HeaderTitle from './HeaderTitle.astro';
---
<header
  id="header-desktop"
  class="site-header fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[95%] max-w-4xl rounded-[var(--border-radius-header)] shadow-lg px-4 py-2 hidden md:flex justify-between items-center"
>
  <a href="/" class="font-bold text-xl text-text" aria-label="Ir al inicio del portfolio de Ramiro Garcia">
    <HeaderTitle />
  </a>
  <nav class="flex items-center gap-4">
    <a href="#projects" class="text-text/80 hover:text-primary transition-colors">Proyectos</a>
    <a href="#contact" class="text-text/80 hover:text-primary transition-colors">Contacto</a>
    <HeaderControls mobile={false} />
  </nav>
</header>
