---
// src/components/Projects.astro
import BackgroundShapes from './BackgroundShapes.astro';
import ProjectsSlider from './ProjectsSlider.tsx';

const projects = [
  {
    title: "LingoHive – Academia de inglés",
    status: "Online",
    description: "Landing animada e interactiva para una academia de inglés. Incluye animaciones, un campo de estrellas y secciones como precios, testimonios y contacto.",
    tags: ["Astro", "React", "GSAP", "ThreeJS", "Swiper", "Responsive"],
    link: "https://www.lingohive.fun",
    cta: "Ver",
  },
  {
    title: "Calza Vila – Mayorista de calzados",
    status: "Online",
    description: "Landing page para un mayorista de calzados, con secciones informativas, formulario de contacto, mapa interactivo de clientes y modos claro/oscuro.",
    tags: ["React", "Tailwind", "Responsive", "Dark mode"],
    link: "https://www.calzavila.com.ar",
    cta: "Ver",
  },
  {
    title: "Fulbo Stats",
    status: "Online",
    description: "Web app en la que te registrás solo o con amigos y registrás tus goles, asistencias y estadísticas de fútbol.",
    tags: ["Vite", "TypeScript", "Tailwind CSS", "Supabase", "Vercel", "Dark mode"],
    link: "https://fulbostats.vercel.app",
    cta: "Ver",
  },
  {
    title: "Webs a medida",
    status: "En desarrollo",
    description: "Plantilla propia para vender sitios web buenos, bonitos y baratos, orientada a clientes reales.",
    tags: ["Astro", "Tailwind CSS", "Responsive"],
    cta: "En desarrollo",
  },
  {
    title: "Dragon Ball Stock Manager",
    status: "En desarrollo",
    description: "Mini marketplace nicho para cartas y productos de Dragon Ball, con registro de vendedores, publicación de productos y gestión de stock desde un panel simple.",
    tags: ["Stack por definir"],
    cta: "En desarrollo",
  }
];
---
<section id="projects" class="relative py-20">
  <BackgroundShapes section="projects" />
  <div class="relative container mx-auto max-w-7xl py-20">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-text mb-12">
      Mis Proyectos
    </h2>

    <!-- Desktop usa grilla estable; mobile conserva carrusel con puntos. -->
    <ProjectsSlider client:media="(max-width: 767px)" projects={projects} />
  </div>

  <style is:global>
    .projects-swiper { padding-bottom: 36px; overflow: hidden; }
    .projects-swiper .swiper-wrapper { align-items: stretch; }
    .projects-swiper .swiper-slide { height: auto; }
    .projects-swiper .card-wrap { height: 100%; }

    .projects-swiper .swiper-pagination-bullet {
      background: var(--text-color);
      opacity: .3;
    }
    .projects-swiper .swiper-pagination-bullet-active {
      background: var(--primary-color);
      opacity: 1;
    }
  </style>
</section>
