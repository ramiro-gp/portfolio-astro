---
// src/components/BackgroundShapes.astro
interface Props {
  section: 'hero' | 'projects' | 'contact';
}

const { section } = Astro.props;
---
<div class="absolute inset-0 z-0">
  {/* Renderiza las figuras solo si la sección es "hero" */}
  {section === 'hero' && (
    <>
      <div class="shapes-neobrutalist">
        <div class="absolute top-[15%] right-[25%] h-20 w-20 border-2 border-primary rotate-12"></div> {/* Cuadrado */}
        <div class="absolute bottom-[20%] right-[10%] h-28 w-28 bg-accent/50 rounded-full"></div> {/* Círculo */}
        <div class="absolute top-[55%] left-[10%] h-16 w-16 bg-primary/50 rounded-xl animate-spin-slow"></div> {/* Cuadrado con bordes redondos */}
      </div>

      <div class="shapes-square">
        <div class="absolute top-[10%] left-[15%] h-24 w-24 bg-primary/20"></div>
        <div class="absolute top-[25%] right-[20%] h-24 w-24 bg-primary/20"></div>
        <div class="absolute bottom-[15%] right-[10%] h-32 w-32 bg-accent/20"></div>
      </div>
      
      <div class="shapes-glass">
        <div class="absolute -top-1/4 -left-1/4 h-[50vw] w-[50vw] rounded-full bg-primary/50"></div>

        <div class="hidden md:block absolute bottom-[-15%] right-[-15%] h-[30vw] w-[30vw] rounded-full bg-accent/50"></div>
        
        {/* <div class="absolute top-0 left-0 pointer-events-none">
          <div class="h-[90vw] w-[90vw] md:h-[60vw] md:w-[60vw] xl:h-[50vw] xl:w-[50vw] rounded-full bg-primary/50 -translate-x-[25%] -translate-y-[25%] transform-gpu"></div>
        </div> */}

      
      </div>

      <div class="shapes-tech">
        <div class="absolute top-[14%] left-[8%] h-px w-40 bg-primary/35"></div>
        <div class="absolute top-[14%] left-[8%] h-24 w-px bg-primary/25"></div>
        <div class="absolute right-[12%] top-[20%] h-24 w-24 border border-primary/25"></div>
        <div class="absolute right-[18%] bottom-[22%] h-px w-52 bg-accent/35"></div>
        <div class="absolute right-[18%] bottom-[22%] h-16 w-px bg-accent/25"></div>
      </div>
    </>
  )}

  {/* Renderiza las figuras solo si la sección es "projects" */}
  {section === 'projects' && (
    <>
      <div class="shapes-neobrutalist">
        <div class="absolute bottom-[10%] right-[12%] h-16 w-16 bg-primary/50 -rotate-12 animate-spin-slow"></div>
        <div class="absolute top-[20%] left-[20%] h-20 w-20 bg-primary/50 rounded-full"></div>
      </div>

      <div class="shapes-square">
        <div class="absolute top-[20%] right-[15%] h-28 w-28 bg-primary/20"></div>
      </div>
      
      <div class="shapes-glass">
        <div class="absolute top-[30%] left-[-5%] h-[35vw] w-[35vw] rounded-full bg-accent/50"></div>
      </div>

      <div class="shapes-tech">
        <div class="absolute left-[6%] top-[28%] h-px w-56 bg-primary/30"></div>
        <div class="absolute left-[6%] top-[28%] h-20 w-px bg-primary/20"></div>
        <div class="absolute bottom-[12%] right-[10%] h-28 w-28 border border-accent/25"></div>
      </div>
    </>
  )}

  {/* Renderiza las figuras solo si la sección es "contact" */}
  {section === 'contact' && (
    <>
      <div class="shapes-neobrutalist">
        <div class="absolute top-[15%] left-[10%] h-30 w-30 bg-accent/50 rounded-2xl rotate-45"></div>
        <div class="absolute bottom-[20%] right-[15%] h-20 w-20 border-2 border-primary rounded-full"></div>
      </div>
       <div class="shapes-square">
        <div class="absolute bottom-[10%] right-[20%] h-24 w-24 bg-primary/10"></div>
      </div>
      <div class="shapes-glass">
        <div class="absolute top-[10%] right-[5%] h-[20vw] w-[20vw] rounded-full bg-primary/50"></div>
      </div>

      <div class="shapes-tech">
        <div class="absolute top-[18%] right-[12%] h-px w-44 bg-primary/30"></div>
        <div class="absolute top-[18%] right-[12%] h-20 w-px bg-primary/20"></div>
        <div class="absolute bottom-[18%] left-[10%] h-20 w-20 border border-accent/25"></div>
      </div>
    </>
  )}
</div>
